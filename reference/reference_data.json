  "validation_rules": {
    "hard_rules": [
      "Every attack_action MUST have resist != null",
      "Every tactical_action MUST have resist == null",
      "Every tactical_action MUST have action_type == null",
      "Every trigger.timing must be one of the 6 enum values",
      "Every attack action_type must be melee, missile, magic, or variable",
      "model_limit must equal 1 for Unique models",
      "model_limit must equal parsed N for Minion(N) or Peon(N)",
      "Masters must have crew_card_name != null and totem != null"
    ],
    "soft_rules": [
      "infuses_soulstone_on_death is usually true; false mainly for Peons",
      "cost is usually '-' for Masters and Totems",
      "Totems are usually Unique",
      "soulstone_cost > 0 should have soulstone icon prefix on card"
    ],
    "hallucination_patterns": [
      "WP/SP swap \u00e2\u20ac\u201d bottom-left vs top-right confusion",
      "Health count off-by-one on high-HP models (14+)",
      "Missing last trigger on an action",
      "Stat copy errors between titles of the same model",
      "Trigger timing defaulting incorrectly",
      "Confusing signature (feather) icon with soulstone (gem) icon",
      "Fabricating abilities from similar models or older editions"
    ]
  },
  "pdf_filename_patterns": {
    "stat_card": "M4E_Stat_{Faction}_{Keyword}_{ModelName}.pdf",
    "crew_card": "M4E_Crew_{Keyword}_{MasterName}_{Title}.pdf",
    "examples": [
      "M4E_Stat_BigHat_Bayou_Gremlin_A.pdf",
      "M4E_Stat_ByuVersatile_Crossroads_Gluttony.pdf",
      "M4E_Crew_BigHat_Somer_Teeth_Jones_Bayou_Boss.pdf"
    ],
    "_note": "Suffixes _A, _B, _C etc. indicate alt-art variants with identical game data."
  }
