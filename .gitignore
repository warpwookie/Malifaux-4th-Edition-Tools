# ===========================================
# M4E Parser - Git Ignore Rules
# ===========================================


# SQLite temporary files (the .db itself is tracked)
*.db-journal
*.db-wal
*.db-shm

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
*.egg
.venv/
venv/

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Temporary files
*.tmp
*.bak

.claude/worktrees/awesome-mirzakhani/
